{
  "name": "@mumble/web-client",
  "version": "0.1.0",
  "private": true,
  "description": "Stubbed Mumble web and Electron client bootstrap",
  "author": "The Mumble Developers",
  "repository": {
    "type": "git",
    "url": "https://github.com/freelin-hummel/mumble.git"
  },
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "start": "node scripts/dev-server.mjs",
    "test": "node --test tests/*.test.mjs",
    "build:web": "node scripts/build-web.mjs",
    "start:electron": "electron .",
    "build:electron": "npm run build:web && electron-builder --dir --publish never",
    "package:electron": "npm run build:web && electron-builder --publish never"
  },
  "build": {
    "appId": "info.mumble.webclient",
    "productName": "Mumble Web Client",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.mjs"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.social-networking"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "devDependencies": {
    "electron": "40.6.1",
    "electron-builder": "26.8.2"
  }
}
