{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "../dist/electron",
    "rootDir": ".",
    "strict": true,
    "noEmitOnError": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "electron"]
  },
  "include": ["main.ts", "preload.ts", "mumble/**/*.ts"],
  "exclude": ["mumble/**/*.test.ts"]
}
